                <elementReference>Iterate_Inventories.mfg_Warehouse__r.mfg_Warehouse_Linking_Code__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Respective_Production_WareHouse</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Frame_Production_Order</name>
        <label>Frame Production Order</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>productionOrder</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>newProductionOrder</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>productionOrder.mfg_Warehouse__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>currentItem_Respective_Production_WareHouse.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>productionOrder.mfg_Product__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Iterate_Inventories.mfg_Product__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>productionOrder.mfg_Estimated_Start__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>today</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>productionOrder.mfg_Priority__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Medium</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>productionOrder.mfg_Quantity_Ordered__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>calculatedProductProductionQuantity</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Add_Production_Order_In_Collection_To_Insert</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Initiate_Inventories</name>
        <label>Initiate Inventories</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>InventoriesBelowSafetyLevel</assignToReference>
