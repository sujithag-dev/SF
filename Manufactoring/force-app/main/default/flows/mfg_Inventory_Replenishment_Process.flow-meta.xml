            </value>
        </assignmentItems>
        <connector>
            <targetReference>Get_Production_Warehouses</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Initiate_Production_Warehouses</name>
        <label>Initiate Production Warehouses</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>productionWarehouses</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_Production_Warehouses</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Iterate_Inventories</targetReference>
        </connector>
    </assignments>
    <collectionProcessors>
        <name>Respective_Production_WareHouse</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Respective Production WareHouse</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNextValueToReference>currentItem_Respective_Production_WareHouse</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>productionWarehouses</collectionReference>
        <conditionLogic>and</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Respective_Production_WareHouse.mfg_Warehouse_Linking_Code__c</leftValueReference>
            <operator>Contains</operator>
            <rightValue>
                <elementReference>Iterate_Inventories.mfg_Warehouse__r.mfg_Warehouse_Linking_Code__c</elementReference>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>Is_Respective_Warehouse_Filtered</targetReference>
        </connector>
    </collectionProcessors>
    <decisions>
        <name>Are_Inventories_below_Safety_level_found</name>
        <label>Are Inventories below Safety level found ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No, Inventories Not Found</defaultConnectorLabel>
        <rules>
            <name>Yes_Inventories_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Inventories</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Initiate_Inventories</targetReference>
            </connector>
            <label>Yes, Inventories Found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Are_Production_Warehouses_Found</name>
        <label>Are Production Warehouses Found ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No, Production Warehouses are not found</defaultConnectorLabel>
        <rules>
            <name>Yes_Production_Warehouses_are_found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Production_Warehouses</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Initiate_Production_Warehouses</targetReference>
            </connector>
            <label>Yes, Production Warehouses are found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Do_Have_Production_Orders_To_Insert</name>
        <label>Do Have Production Orders To Insert ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No, Do not have Production Orders To Insert</defaultConnectorLabel>
        <rules>
            <name>Yes_Have_Production_Orders_To_Insert</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>productionOrdersToInsert</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Production_Orders</targetReference>
            </connector>
            <label>Yes, Have Production Orders To Insert</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Respective_Warehouse_Filtered</name>
        <label>Is Respective Warehouse Filtered ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Iterate_Inventories</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No, Respective Warehouse not filtered</defaultConnectorLabel>
        <rules>
            <name>Yes_Respective_Warehouse_Filtered</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Respective_Production_WareHouse</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Iterate_Production_Warehouses</targetReference>
            </connector>
            <label>Yes, Respective Warehouse Filtered</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Respective_Warehouse_Found</name>
        <label>Is Respective Warehouse Found?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Iterate_Production_Warehouses</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No, Respective Warehouse not found</defaultConnectorLabel>
        <rules>
            <name>Yes_Respective_Warehouse_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>currentItem_Respective_Production_WareHouse.mfg_Warehouse_Linking_Code__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <elementReference>Iterate_Inventories.mfg_Warehouse__r.mfg_Warehouse_Linking_Code__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Frame_Production_Order</targetReference>
            </connector>
            <label>Yes, Respective Warehouse Found</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>calculatedProductProductionQuantity</name>
        <dataType>Number</dataType>
        <expression>BLANKVALUE(
  {!Iterate_Inventories.mfg_Reorder_Point_Units__c},
  0
)
-
BLANKVALUE(
  {!Iterate_Inventories.mfg_Available_Quantity__c},
  0
)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>today</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <interviewLabel>Inventory Replenishment Process - mfg_Inventory_Replenishment_Process {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Inventory Replenishment Process</label>
    <loops>
