        <label>Debug</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>debugconsole</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>currentItem_Respective_Production_WareHouse.mfg_Warehouse_Linking_Code__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>debugConsole2</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Iterate_Inventories.mfg_Warehouse__r.mfg_Warehouse_Linking_Code__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Is_Respective_Warehouse_Found</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>debug_linking_code</name>
        <label>debug linking code</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>debuglinkingcode</assignToReference>
            <operator>Assign</operator>
