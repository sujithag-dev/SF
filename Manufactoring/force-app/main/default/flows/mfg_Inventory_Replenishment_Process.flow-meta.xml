        <label>Iterate Inventories</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>InventoriesBelowSafetyLevel</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
