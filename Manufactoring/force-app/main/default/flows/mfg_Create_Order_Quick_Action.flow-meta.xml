        </fields>
        <nextOrFinishButtonLabel>Close</nextOrFinishButtonLabel>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_Flow_Access_Allowed</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <subflows>
        <description>It’s an auto-launched flow that receives an Opportunity or Quote record ID, creates an Order based on it, and then returns the Order ID, a success message, and a boolean indicating whether the operation was successful.</description>
        <name>mfg_Order_Creation</name>
        <label>Order Creation</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_Order_Created</targetReference>
        </connector>
        <flowName>mfg_Order_Creation</flowName>
        <inputAssignments>
            <name>recordId</name>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </inputAssignments>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </subflows>
    <variables>
        <name>recordId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
