        </connector>
    </assignments>
    <assignments>
        <name>Reduce_Product_Batch_Quantity</name>
        <label>Reduce Product Batch Quantity</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>productionBatchQuantity</assignToReference>
            <operator>Subtract</operator>
            <value>
                <numberValue>1.0</numberValue>
            </value>
        </assignmentItems>
        <connector>
            <isGoTo>true</isGoTo>
            <targetReference>Are_Production_Batch_Units_Framed_Based_On_Production_Batch_Quantity</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Are_Production_Batch_Units_Framed_Based_On_Production_Batch_Quantity</name>
        <label>Are Production Batch Units Framed Based On Production Batch Quantity</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Frame_Production_Batch_Unit</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No, Production Batch Units Are Not Framed</defaultConnectorLabel>
        <rules>
            <name>Yes_Production_Batch_Units_Are_Framed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>productionBatchQuantity</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Are_the_Production_Batch_Unit_records_required_to_be_Inserted</targetReference>
            </connector>
            <label>Yes, Production Batch Units Are Framed</label>
        </rules>
    </decisions>
    <decisions>
        <name>Are_the_Production_Batch_Unit_records_required_to_be_Inserted</name>
        <label>Are the Production Batch Unit records required to be Inserted?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No,Records Are Not There To Insert</defaultConnectorLabel>
        <rules>
            <name>Yes_Records_are_there_to_Insert</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>productBatchUnitsToInsert</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Production_Batch_Units</targetReference>
            </connector>
            <label>Yes, Records are there to Insert</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Production_Batch_Found</name>
        <label>Is Production Batch Found?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No, Production Batch Not Found</defaultConnectorLabel>
        <rules>
            <name>Yes_Production_Batch_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Production_Batch.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Initiate_Production_Batch_And_Quantity</targetReference>
            </connector>
            <label>Yes, Production Batch Found</label>
        </rules>
    </decisions>
