    </assignments>
    <assignments>
        <name>Frame_Production_Batch_Unit</name>
        <label>Frame Production Batch Unit</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>productBatchUnit</assignToReference>
            <operator>Assign</operator>
