            <value>
                <elementReference>productionBatch.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>productBatchUnit.mfg_Product__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>productionBatch.mfg_Product__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Add_Production_Batch_Unit_In_Collection</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Initiate_Production_Batch_And_Quantity</name>
        <label>Initiate Production Batch And Quantity</label>
        <locationX>0</locationX>
