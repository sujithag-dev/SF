    <assignments>
        <name>Collect_Inventories_To_Update_in_Collection</name>
        <label>Collect Inventories To Update in Collection</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>inventoriesToUpdate</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>inventory</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Iterate_Transport_Products</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Frame_Inventory_To_Update</name>
        <label>Frame Inventory To Update</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>inventory</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>newInventory</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>inventory.Id</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>filteredInventory.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>inventory.mfg_Quantity_On_Hand__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>filteredInventory.mfg_Quantity_On_Hand__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>inventory.mfg_Quantity_On_Hand__c</assignToReference>
            <operator>Subtract</operator>
            <value>
                <elementReference>Iterate_Transport_Products.mfg_Product_Quantity__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>inventory.mfg_Reserved_Quantity__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>filteredInventory.mfg_Reserved_Quantity__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>inventory.mfg_Reserved_Quantity__c</assignToReference>
            <operator>Subtract</operator>
            <value>
                <elementReference>Iterate_Transport_Products.mfg_Product_Quantity__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Collect_Inventories_To_Update_in_Collection</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Initiate_Exact_Inventory</name>
        <label>Initiate Exact Inventory</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>filteredInventory</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>newInventory</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>filteredInventory</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Iterate_Filtered_Inventory</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Iterate_Filtered_Inventory</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Initiate_Inventories</name>
        <label>Initiate Inventories</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>inventories</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_Related_Inventories_of_Transport_Products</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Iterate_Transport_Products</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Initiate_Transport_And_Schedule</name>
        <label>Initiate Transport And Schedule</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>transportSchedule</assignToReference>
