        </connector>
    </assignments>
    <collectionProcessors>
        <name>Filter_Inventory_Basedon_Product</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Filter Inventory Basedon Product</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNextValueToReference>currentItem_Filter_Inventory_Basedon_Product</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>inventories</collectionReference>
        <conditionLogic>and</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Filter_Inventory_Basedon_Product.mfg_Product__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <elementReference>Iterate_Transport_Products.mfg_Product__c</elementReference>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>Iterate_Filtered_Inventory</targetReference>
        </connector>
    </collectionProcessors>
    <decisions>
        <name>Are_Inventories_found</name>
        <label>Are Inventories found ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No, Inventories are not found</defaultConnectorLabel>
        <rules>
            <name>Yes_Inventories_are_found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Related_Inventories_of_Transport_Products</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Initiate_Inventories</targetReference>
            </connector>
            <label>Yes, Inventories are found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Are_there_any_Inventory_records_that_need_to_be_updated</name>
        <label>Are there any Inventory records that need to be updated?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No, Inventories are not there to update</defaultConnectorLabel>
        <rules>
            <name>Yes_Inventories_are_there_to_update</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>inventoriesToUpdate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Inventories</targetReference>
            </connector>
            <label>Yes, Inventories are there to update</label>
        </rules>
    </decisions>
    <decisions>
        <name>Are_Transport_Products_Found</name>
        <label>Are Transport Products Found ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No, Transport Products Not Found</defaultConnectorLabel>
        <rules>
            <name>Yes_Transport_Products_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Transport_Products</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Initiate_Transport_Products</targetReference>
            </connector>
            <label>Yes, Transport Products Found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Product_Status_Set_to_Product_Collected_In_Transport_And_Schedule</name>
        <label>Is Product Status Set to Product Collected In Transport And Schedule ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No, Product Status is not Product Collected</defaultConnectorLabel>
        <rules>
            <name>Yes_Product_Status_is_Product_Collected</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>transportSchedule.mfg_Product_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Products Collected</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Transport_Products</targetReference>
            </connector>
            <label>Yes, Product Status is Product Collected</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Transport_And_Schedule_Found</name>
        <label>Is Transport And Schedule Found ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No, Transport And Schedule Not Found</defaultConnectorLabel>
        <rules>
            <name>Yes_Transport_And_Schedule_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Transport_And_Schedule.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Initiate_Transport_And_Schedule</targetReference>
            </connector>
            <label>Yes, Transport And Schedule Found</label>
        </rules>
    </decisions>
    <environments>Default</environments>
