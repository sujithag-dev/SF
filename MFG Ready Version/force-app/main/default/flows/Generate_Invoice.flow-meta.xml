        <defaultConnectorLabel>Other Order</defaultConnectorLabel>
        <rules>
            <name>Activated_Order</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ShowErrorMessage</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Invoice Generated</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Generate_Invoice</targetReference>
            </connector>
            <label>Activated Order</label>
        </rules>
