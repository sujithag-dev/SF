    <formulas>
        <name>InvoiceStatus</name>
        <dataType>String</dataType>
        <expression> IF({!Invoice_Is_Finalized}= &apos;Yes&apos;, &apos;Posted&apos;, &apos;Draft&apos;)</expression>
    </formulas>
    <formulas>
        <name>ShowErrorMessage</name>
        <dataType>String</dataType>
        <expression> IF( ISPICKVAL( {!Order.Status}, &apos;Draft&apos;), &apos;The Order must be in Activated status to generate an invoice.&apos;, IF(ISPICKVAL( {!Order.Status}, &apos;Rejected&apos;), &apos;Rejected orders are not eligible for invoice generation&apos;, IF(ISPICKVAL({!Order.Status}, &apos;Invoice Generated&apos;), &apos;This order already has a generated invoice&apos;, &apos;Invoice Generated&apos;)))</expression>
    </formulas>
