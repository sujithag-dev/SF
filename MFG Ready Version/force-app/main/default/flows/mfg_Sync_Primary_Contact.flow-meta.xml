            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>accountToInsert.Id</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Account</targetReference>
            </connector>
            <label>Yes, Account is there to update</label>
        </rules>
    </decisions>
