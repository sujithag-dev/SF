    <decisions>
        <name>Are_there_Contacts_to_update</name>
        <label>Are there Contacts to update ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No, Contacts are not there to update</defaultConnectorLabel>
        <rules>
            <name>Yes_Contacts_are_there_to_update</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>contactsToUpdate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Contacts</targetReference>
            </connector>
            <label>Yes, Contacts are there to update</label>
        </rules>
    </decisions>
    <decisions>
        <name>If_Primary_Contact_in_related_account_is</name>
        <label>If Primary Contact in related account is</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Others</defaultConnectorLabel>
        <rules>
            <name>Not_Populated</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>contact.Account.mfg_Primary_Contact__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Primary_Contact</targetReference>
            </connector>
            <label>Not Populated</label>
        </rules>
        <rules>
            <name>Populated_With_Same_Contact</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>contact.Account.mfg_Primary_Contact__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>contact.Account.mfg_Primary_Contact__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>recordId</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Already_Primary_Contact</targetReference>
            </connector>
            <label>Populated With Same Contact</label>
        </rules>
        <rules>
            <name>Populated_With_Different_Contact</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>contact.Account.mfg_Primary_Contact__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>contact.Account.mfg_Primary_Contact__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>recordId</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Change_Primary_Contact</targetReference>
            </connector>
            <label>Populated With Different Contact</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Contact_Found</name>
        <label>Is Contact Found?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No, Contact With Account Id Not Found</defaultConnectorLabel>
        <rules>
            <name>Yes_Contact_Found_With_AccountId_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>contact</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>If_Primary_Contact_in_related_account_is</targetReference>
            </connector>
            <label>Yes, Contact Found With AccountId Found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Flow_Access_Allowed</name>
        <label>Is Flow Access Allowed?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No, Flow Access Not Allowed</defaultConnectorLabel>
        <rules>
            <name>Yes_Flow_Access_Allowed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Label.mfg_Activate</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Label.mfg_Activate_Flow</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_RecordId_Populated</targetReference>
            </connector>
            <label>Yes, Flow Access Allowed</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_RecordId_Populated</name>
        <label>Is RecordId Populated?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No, RecordId is not Populated</defaultConnectorLabel>
        <rules>
            <name>Yes_RecordId_is_populated</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recordId</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Contact_With_AccountId</targetReference>
            </connector>
            <label>Yes, RecordId is populated</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_there_account_to_update</name>
        <label>Is there account to update ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>User_Notification</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No, Account is not there to update</defaultConnectorLabel>
        <rules>
