    <decisions>
        <name>Check_Parent_Contact_Is_Created_Or_Updated</name>
        <label>Check Parent Contact Is Created Or Updated</label>
        <locationX>446</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Parent_Contact_Is_Created</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_New_Parent_Contact_As_Primary_Contact</targetReference>
            </connector>
            <label>Parent Contact Is Created</label>
        </rules>
        <rules>
            <name>Parent_Contact_Is_Updated</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_Primary_Contact_Is_Checked_By_The_User</targetReference>
            </connector>
            <label>Parent Contact Is Updated</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Primary_Contact_Is_Checked_By_The_User</name>
        <label>Check Primary Contact Is Checked By The User</label>
        <locationX>446</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Primary_Contact_Is_Checked_By_The_User</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Primary_Contact__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Primary_Contact__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Other_Primary_Contact_Checkbox</targetReference>
            </connector>
            <label>Yes, Primary Contact Is Checked By The User</label>
        </rules>
    </decisions>
    <environments>Default</environments>
