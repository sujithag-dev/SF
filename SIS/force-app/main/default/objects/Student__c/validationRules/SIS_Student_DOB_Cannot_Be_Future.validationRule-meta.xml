<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>SIS_Student_DOB_Cannot_Be_Future</fullName>
    <active>true</active>
    <errorConditionFormula>Date_of_Birth__c  &gt;= TODAY()</errorConditionFormula>
    <errorDisplayField>Date_of_Birth__c</errorDisplayField>
    <errorMessage>Date of Birth cannot be future date.</errorMessage>
</ValidationRule>
