<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>SIS_Validate_Mobile_Number_3</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISBLANK(Mobile_Phone_3__c)),
  NOT(REGEX( Mobile_Phone_3__c , &quot;^\\+?[0-9]{10,12}$&quot;))
)</errorConditionFormula>
    <errorDisplayField>Mobile_Phone_3__c</errorDisplayField>
    <errorMessage>Enter a valid number with 10 to 12 digits.</errorMessage>
</ValidationRule>
