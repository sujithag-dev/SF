<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>SIS_Passport_Expiry_Validation</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT(ISBLANK(Passport_Expiry__c )),
     Passport_Expiry__c &lt;= TODAY()
)</errorConditionFormula>
    <errorMessage>Passport Expiry Date must be a future date.</errorMessage>
</ValidationRule>
