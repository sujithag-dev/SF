<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>SIS_Postcode_Validation</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT(ISBLANK( Postcode__c )),  
    NOT(REGEX( Postcode__c , &quot;^[0-9]+$&quot;))  
)</errorConditionFormula>
    <errorDisplayField>Postcode__c</errorDisplayField>
    <errorMessage>Postcode should contain only numbers.</errorMessage>
</ValidationRule>
