<?xml version="1.0" encoding="UTF-8"?>
<MatchingRules xmlns="http://soap.sforce.com/2006/04/metadata">
    <matchingRules>
        <fullName>SIS_Matching_Rule_For_Parent_Lead</fullName>
        <booleanFilter>1 OR 2</booleanFilter>
        <description>Email and Mobile Number Fields are  already exist.</description>
        <label>SIS Matching Rule For Parent Lead</label>
        <matchingRuleItems>
            <blankValueBehavior>NullNotAllowed</blankValueBehavior>
            <fieldName>Email__c</fieldName>
